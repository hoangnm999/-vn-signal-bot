# ════════════════════════════════════════════════════════════════
#  .env.example  —  Copy thành .env để dev local
#  ĐỪNG commit file .env thật lên GitHub!
# ════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
CHAT_ID=your_chat_id
ALLOWED_CHAT_IDS=your_chat_id,other_chat_id

# ── LLM (waterfall: DeepSeek → OpenRouter → Groq → Gemini) ────────
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Data sources ───────────────────────────────────────────────────
# Lấy từ: https://fireant.vn → Tài khoản → Lấy token API
FIREANT_TOKEN=

# ── Database ────────────────────────────────────────────────────────
# Local: postgresql://user:pass@localhost:5432/vnsignal
# Render: lấy từ dashboard (Internal URL)
DATABASE_URL=postgresql://vnsignal_user:password@localhost:5432/vnsignal

# ── Vibe-Trading ────────────────────────────────────────────────────
VIBE_API_URL=https://hkuds-vibe-trading-production.up.railway.app
VIBE_API_KEY=your_vibe_api_key

# ── Watchlist ────────────────────────────────────────────────────────
WATCHLIST=VCB,HPG,FPT,VNM,MWG,TCB,VHM,SSI,HDB,BID

# ── Paths (Render: /data | Local: ./data) ────────────────────────────
DATA_DIR=./data
REPORT_DIR=./data/reports

# ── Runtime ──────────────────────────────────────────────────────────
TZ=Asia/Ho_Chi_Minh
PYTHONUNBUFFERED=1
